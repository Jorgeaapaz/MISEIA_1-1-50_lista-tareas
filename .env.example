# Copia este archivo a .env.local y rellena los valores reales
# cp .env.example .env.local

# URI de conexión a MongoDB (requerido)
# Formato: mongodb://usuario:contraseña@host:puerto/?authSource=admin
MONGODB_URI=mongodb://your-user:your-password@your-host:27017/?authSource=admin

# Nombre de la base de datos (requerido)
MONGODB_DB=lista_tareas
